---
import Link from "../components/Link.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <section aria-labelledby="projects-heading">
    <h1 id="projects-heading" class="sr-only">Projects</h1>
    <ol class="list-none space-y-4 p-0">
      <li class="rounded-2xl border border-[var(--border)] bg-[var(--bg-elevated)]/40 p-5 transition-colors hover:border-[color-mix(in_srgb,var(--accent)_28%,var(--border))] sm:p-6">
        <h2 class="text-base font-semibold text-[var(--text)]">
          <Link href="https://github.com/AlexGaudon/tallyo">Tallyo</Link>
        </h2>
        <p class="mt-2 text-sm leading-relaxed text-[var(--text-muted)] sm:text-base">
          My take on a personal finance tracker, since <Link href="https://en.wikipedia.org/wiki/Intuit_Mint#Shut_down">Mint</Link> ran out of money.
        </p>
      </li>
      <li class="rounded-2xl border border-[var(--border)] bg-[var(--bg-elevated)]/40 p-5 transition-colors hover:border-[color-mix(in_srgb,var(--accent)_28%,var(--border))] sm:p-6">
        <h2 class="text-base font-semibold text-[var(--text)]">
          <Link href="https://github.com/AlexGaudon/overs.sh">overs.sh</Link>
        </h2>
        <p class="mt-2 text-sm leading-relaxed text-[var(--text-muted)] sm:text-base">
          Super simple file transfer between servers over SSH. Dead easy.
        </p>
      </li>
      <li class="rounded-2xl border border-[var(--border)] bg-[var(--bg-elevated)]/40 p-5 transition-colors hover:border-[color-mix(in_srgb,var(--accent)_28%,var(--border))] sm:p-6">
        <h2 class="text-base font-semibold text-[var(--text)]">
          <Link href="https://misery.systems">misery.systems</Link>
        </h2>
        <p class="mt-2 text-sm leading-relaxed text-[var(--text-muted)] sm:text-base">
          Where I mess around with my homelab (yeah, it&apos;s really called &quot;misery.systems&quot;).
        </p>
      </li>
      <li class="rounded-2xl border border-[var(--border)] bg-[var(--bg-elevated)]/40 p-5 transition-colors hover:border-[color-mix(in_srgb,var(--accent)_28%,var(--border))] sm:p-6">
        <h2 class="text-base font-semibold text-[var(--text)]">
          <Link href="https://github.com/AlexGaudon/stocky">stocky</Link>
        </h2>
        <p class="mt-2 text-sm leading-relaxed text-[var(--text-muted)] sm:text-base">A Discord bot that spits out stock prices on command.</p>
      </li>
      <li class="rounded-2xl border border-[var(--border)] bg-[var(--bg-elevated)]/40 p-5 transition-colors hover:border-[color-mix(in_srgb,var(--accent)_28%,var(--border))] sm:p-6">
        <h2 class="text-base font-semibold text-[var(--text)]">
          <Link href="https://github.com/alexgaudon/ntfy-bridge">ntfy-bridge</Link>
        </h2>
        <p class="mt-2 text-sm leading-relaxed text-[var(--text-muted)] sm:text-base">
          Bridges Discord and <Link href="https://ntfy.sh">ntfy.sh</Link> so you can get notifications wherever you want.
        </p>
      </li>
      <li class="rounded-2xl border border-[var(--border)] bg-[var(--bg-elevated)]/40 p-5 transition-colors hover:border-[color-mix(in_srgb,var(--accent)_28%,var(--border))] sm:p-6">
        <h2 class="text-base font-semibold text-[var(--text)]">
          <Link href="https://github.com/alexgaudon/lootsheet">LootSheet</Link>
        </h2>
        <p class="mt-2 text-sm leading-relaxed text-[var(--text-muted)] sm:text-base">A simple group hunting loot splitter for Tibia.</p>
      </li>
    </ol>
  </section>
</Layout>
