---
import Link from "../components/Link.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <section class="animate-rise space-y-10">
    <div class="space-y-4">
      <h1 class="text-4xl font-semibold tracking-tight text-[var(--text)] sm:text-5xl">
        Hey, I&apos;m <span class="text-[var(--accent)]">Alex Gaudon</span>.
      </h1>
      <p class="max-w-xl text-lg leading-relaxed text-[var(--text-muted)]">I build web stuff.</p>
    </div>

    <ul class="animate-rise animate-rise-delay-1 space-y-5 border-t border-[var(--border)] pt-10 text-base leading-relaxed text-[var(--text-muted)]">
      <li>
        Software Dev @ <Link href="https://www.colabsoftware.com">CoLab Software</Link>
      </li>
      <li>
        Building <Link href="https://github.com/AlexGaudon/tallyo">Tallyo</Link> in my free time.
      </li>
      <li>
        Prev Software Dev @ <Link href="https://www.clearrisk.com">ClearRisk</Link>
      </li>
      <li>
        This site has a few of my <Link href="/projects">projects</Link>
      </li>
    </ul>
  </section>
</Layout>
